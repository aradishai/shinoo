generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  coins                Int                @default(0)
  x2Stock           Int                @default(0)
  shinooStock       Int                @default(0)
  x3Stock           Int                @default(0)
  goalsStock        Int                @default(0)
  minute90Stock     Int                @default(0)
  splitStock        Int                @default(0)
  allinStock        Int                @default(0)
  doubleStock       Int                @default(0)
  interests         String[]           @default([])
  avatar            String             @default("⚽")
  leagueMembers     LeagueMember[]
  predictions       Prediction[]
  createdLeagues    League[]
  coinBets          CoinBet[]
  messages          Message[]
  pushSubscriptions PushSubscription[]
}

model Tournament {
  id       String  @id @default(cuid())
  name     String
  nameHe   String
  slug     String  @unique
  type     String  @default("world_cup")
  isActive Boolean @default(true)
  season   String

  matches Match[]
}

model Team {
  id      String  @id @default(cuid())
  nameHe  String
  nameEn  String
  code    String  @unique
  flagUrl String?

  players     Player[]
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
}

model Player {
  id     String @id @default(cuid())
  teamId String
  nameHe String
  nameEn String

  team         Team          @relation(fields: [teamId], references: [id])
  predictions  Prediction[]
  matchScorers MatchScorer[]
}

model Match {
  id              String      @id @default(cuid())
  tournamentId    String
  homeTeamId      String
  awayTeamId      String
  kickoffAt       DateTime
  lockAt          DateTime
  status          String @default("SCHEDULED")
  homeScore       Int?
  awayScore       Int?
  minute          Int?
  minuteAt        DateTime?
  coinsGranted    Boolean     @default(false)
  reminderSent    Boolean     @default(false)
  homeRedCards    Int         @default(0)
  awayRedCards    Int         @default(0)
  hasPenalty      Boolean     @default(false)
  providerMatchId String?     @unique
  round           String?

  tournament  Tournament    @relation(fields: [tournamentId], references: [id])
  homeTeam    Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  scorers     MatchScorer[]
  predictions Prediction[]
}

model MatchScorer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  goals    Int    @default(1)

  match  Match  @relation(fields: [matchId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId])
}

model League {
  id              String   @id @default(cuid())
  name            String
  createdByUserId String
  inviteCode      String   @unique
  createdAt       DateTime @default(now())
  tournamentId    String?

  createdBy   User           @relation(fields: [createdByUserId], references: [id])
  members     LeagueMember[]
  predictions Prediction[]
  messages    Message[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  leagueId  String
  userId    String
  content   String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leagueId, createdAt])
}

model LeagueMember {
  id       String           @id @default(cuid())
  leagueId String
  userId   String
  joinedAt DateTime         @default(now())
  role     String @default("MEMBER")

  league League @relation(fields: [leagueId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

model Prediction {
  id                         String   @id @default(cuid())
  userId                     String
  leagueId                   String
  matchId                    String
  predictedHomeScore         Int
  predictedAwayScore         Int
  predictedTopScorerPlayerId String?
  x2Applied                  Boolean  @default(false)
  shinooApplied              Boolean  @default(false)
  x3Applied                  Boolean  @default(false)
  goalsApplied               Boolean  @default(false)
  minute90Applied            Boolean  @default(false)
  splitApplied               Boolean  @default(false)
  allinApplied               Boolean  @default(false)
  splitHomeScore2            Int?
  splitAwayScore2            Int?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  lockedSnapshot             String?

  user               User              @relation(fields: [userId], references: [id])
  league             League            @relation(fields: [leagueId], references: [id])
  match              Match             @relation(fields: [matchId], references: [id])
  predictedTopScorer Player?           @relation(fields: [predictedTopScorerPlayerId], references: [id])
  points             PredictionPoints?
  coinBet            CoinBet?

  @@unique([userId, leagueId, matchId])
}

model PowerupUsage {
  id         String   @id @default(cuid())
  userId     String
  leagueId   String
  matchday   Int
  type       String   // "X2" | "SHINOO"
  createdAt  DateTime @default(now())

  @@index([userId, leagueId, matchday, type])
}

model CoinBet {
  id           String    @id @default(cuid())
  userId       String
  predictionId String    @unique
  betAmount    Int
  coinsEarned  Int?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())

  user       User       @relation(fields: [userId], references: [id])
  prediction Prediction @relation(fields: [predictionId], references: [id])
}

model AllInPool {
  id        String       @id @default(cuid())
  matchId   String
  leagueId  String
  resolved  Boolean      @default(false)
  createdAt DateTime     @default(now())
  entries   AllInEntry[]

  @@unique([matchId, leagueId])
}

model AllInEntry {
  id           String   @id @default(cuid())
  poolId       String
  userId       String
  predictionId String   @unique
  pointsWon    Int?
  createdAt    DateTime @default(now())

  pool AllInPool @relation(fields: [poolId], references: [id])
}

model DoubleEntry {
  id            String   @id @default(cuid())
  userId        String
  leagueId      String
  predictionId1 String?
  predictionId2 String?
  bonusPoints   Int?
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model PredictionPoints {
  id              String  @id @default(cuid())
  predictionId    String  @unique
  resultPoints    Int     @default(0)
  topScorerPoints Int     @default(0)
  totalPoints     Int     @default(0)
  explanation     String?

  prediction Prediction @relation(fields: [predictionId], references: [id])
}
